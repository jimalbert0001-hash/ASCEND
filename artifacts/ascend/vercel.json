{
  "buildCommand": "cd artifacts/ascend && pnpm install && pnpm run build",
  "outputDirectory": "artifacts/ascend/dist",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ascend-api-server.vercel.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
